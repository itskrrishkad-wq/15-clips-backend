// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id       String        @id @default(uuid())
  name     String
  lname    String
  email    String        @unique
  password String?
  role     AdminUserRole

  createdAt DateTime @default(now())
}

enum AdminUserRole {
  ADMIN
  MANAGER
  GUEST
}

model User {
  id         String    @id @default(uuid())
  name       String?
  lname      String?
  email      String    @unique
  password   String?
  location   String?
  interests  String[]
  languages  String[]
  profession String?
  dob        DateTime?
  phoneNo    String?
  gender     String?

  emailVerified Boolean @default(false)

  dailyTimeSpent Int?
  reasonToJoin   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedReels Reel[]      @relation("SavedReels")
  adEvents   AdEvent[]
  reelViews  ReelView[]
  reelLikes  ReelLike[]
  reelSaveds ReelSaved[]
  reports    Report[]
}

model Reel {
  id              String   @id @default(uuid())
  source          String
  sourceUrl       String
  sourceThumbnail String?
  reelUrl         String
  duration        Int?
  channel         String?
  channelId       String?
  thumbnail       String?
  locations       String[]
  languages       String[]
  professions     String[]
  interests       String[]

  status ReelStatus

  viewCount Int @default(0)
  saveCount Int @default(0)
  likeCount Int @default(0)

  sourceViews Int? @default(0)
  sourceLikee Int? @default(0)

  createdAt DateTime @default(now())

  savedBy    User[]      @relation("SavedReels")
  reelViews  ReelView[]
  reelLikes  ReelLike[]
  reelSaveds ReelSaved[]
  reports    Report[]
}

enum ReelStatus {
  DRAFT
  PUBLISH
  REVIEW
}

model ReelView {
  id String @id @default(uuid())

  userId String
  reelId String

  watchTime Int? // seconds watched (for ranking later) || percentage
  completed Boolean @default(false)
  location  String?
  gender    String?
  age       Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([userId, reelId]) // 🚀 prevents duplicate views
  @@index([reelId])
}

model ReelLike {
  id String @id @default(uuid())

  userId String
  reelId String

  liked    Boolean @default(false)
  location String?
  gender   String?
  age      Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([userId, reelId]) // 🚀 prevents duplicate views
  @@index([reelId])
}

model ReelSaved {
  id String @id @default(uuid())

  userId String
  reelId String

  Saved Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@unique([userId, reelId]) // 🚀 prevents duplicate views
  @@index([reelId])
}

model Ad {
  id               String  @id @default(uuid())
  title            String
  description      String?
  url              String
  redirectUrl      String?
  actionButtonText String?
  type             AdType

  professions String[]
  interests   String[]
  gender      String?
  ageMin      Int?
  ageMax      Int?
  locations   String[]

  startAt DateTime
  endAt   DateTime
  status  AdStatus

  viewCount  Int? @default(0) // impressions
  clickCount Int? @default(0) // clicks

  events AdEvent[] // 👈 relation added

  createdAt DateTime @default(now())
  // adEvents  AdEvent[]
}

enum AdType {
  VIDEO
  IMAGE
}

enum AdStatus {
  ACTIVE
  PAUSED
  SCHEDULED
  COMPLETED
  CANCELED
}

model AdEvent {
  id String @id @default(uuid())

  adId   String
  userId String?

  eventType AdEventType

  // user snapshot data (important for analytics even if user changes later)
  location   String?
  gender     String?
  age        Int?
  profession String?
  interests  String[]
  languages  String[]

  device String? // ios / android / web
  ip     String? // optional (for fraud detection)

  createdAt DateTime @default(now())

  // relations
  ad   Ad    @relation(fields: [adId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([adId])
  @@index([userId])
  @@index([eventType])
}

enum AdEventType {
  VIEW
  CLICK
}

model Report {
  id String @id @default(uuid())

  // who reported
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // which reel
  reelId String
  reel   Reel   @relation(fields: [reelId], references: [id], onDelete: Cascade)

  // why
  reason ReportReason
  note   String?      @db.Text

  // optional (can remove if you want ultra-minimal)
  status ReportStatus @default(PENDING)

  createdAt DateTime @default(now())

  // prevent spam reporting same reel
  @@unique([userId, reelId])
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  VIOLENCE
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
}

model AdSettings {
  id                      String @id @default(uuid())
  numberOfReelsBetweenAds Int // Ads appear after this many reels
}

model Source {
  id          String      @id @default(uuid())
  channelId   String      @unique
  categories  String[]
  language    String
  channelName String
  profileImg  String?
  source      SourceValue
  createdAt   DateTime    @default(now())
  updateAt    DateTime    @updatedAt()
}

enum SourceValue {
  YOUTUBE
  INSTAGRAM
}
